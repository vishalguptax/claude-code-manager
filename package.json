{
  "name": "claude-manager",
  "displayName": "Claude Manager — Sessions, MCP, Skills, Usage & Accounts",
  "description": "Manage Claude Code sessions, MCP servers, skills, slash commands, hooks, agents, account switching & usage tracking from your VS Code sidebar. Resume with git branch detection. 100% local, zero telemetry.",
  "version": "2.0.4",
  "publisher": "vishalguptax",
  "author": {
    "name": "Vishal Gupta",
    "url": "https://github.com/vishalguptax"
  },
  "license": "Apache-2.0",
  "icon": "media/marketplace-icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vishalguptax/claude-manager"
  },
  "homepage": "https://claudemanager.vishalg.in",
  "bugs": {
    "url": "https://github.com/vishalguptax/claude-manager/issues"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Machine Learning",
    "Visualization",
    "Other"
  ],
  "sponsor": {
    "url": "https://github.com/sponsors/vishalguptax"
  },
  "qna": "marketplace",
  "pricing": "Free",
  "keywords": [
    "claude",
    "claude-code",
    "claude-manager",
    "claude-code-manager",
    "anthropic",
    "claude account switcher",
    "claude session manager",
    "claude session management",
    "claude usage tracker",
    "claude token usage",
    "claude skill manager",
    "claude skill management",
    "claude session",
    "claude agents",
    "claude hooks",
    "claude commands",
    "claude mcp",
    "mcp",
    "mcp manager",
    "model-context-protocol",
    "session manager",
    "ai",
    "ai-assistant",
    "ai-coding",
    "llm",
    "vscode",
    "cursor",
    "windsurf",
    "developer-tools",
    "productivity"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCodeManager",
          "title": "Claude Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeCodeManager": [
        {
          "type": "webview",
          "id": "claudeCodeManager.view",
          "name": "Claude Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeManager.open",
        "title": "Claude Manager: Open"
      },
      {
        "command": "claudeManager.switchAccount",
        "title": "Claude Manager: Switch Account"
      },
      {
        "command": "claudeManager.exportBrain",
        "title": "Claude Manager: Export Brain…"
      },
      {
        "command": "claudeManager.importBrain",
        "title": "Claude Manager: Import Brain…"
      },
      {
        "command": "claudeManager.reload",
        "title": "Claude Manager: Reload"
      },
      {
        "command": "claudeManager.runDiagnostics",
        "title": "Claude Manager: Run Diagnostics"
      }
    ],
    "keybindings": [
      {
        "command": "claudeManager.open",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      },
      {
        "command": "claudeManager.reload",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "focusedView == claudeCodeManager.view"
      }
    ],
    "configuration": {
      "title": "Claude Manager",
      "properties": {
        "claudeManager.terminal.location": {
          "type": "string",
          "default": "editor",
          "enum": [
            "editor",
            "panel"
          ],
          "enumDescriptions": [
            "Open terminals in the editor area (beside current editor)",
            "Open terminals in the bottom panel"
          ],
          "description": "Where to open Claude terminals when resuming sessions."
        },
        "claudeManager.terminal.editorPosition": {
          "type": "string",
          "default": "beside",
          "enum": [
            "beside",
            "active",
            "one",
            "two",
            "three"
          ],
          "enumDescriptions": [
            "Open beside the current editor",
            "Open in the active editor group",
            "Open in the first editor group",
            "Open in the second editor group",
            "Open in the third editor group"
          ],
          "description": "Which editor group to open the terminal in (only applies when location is 'editor')."
        },
        "claudeManager.sessions.defaultFilter": {
          "type": "string",
          "default": "recent",
          "enum": [
            "recent",
            "week",
            "month",
            "all"
          ],
          "enumDescriptions": [
            "Show top 20 most recent sessions",
            "Show sessions from the past week",
            "Show sessions from the past month",
            "Show all sessions"
          ],
          "description": "Default date filter when opening the sessions tab."
        },
        "claudeManager.sessions.defaultProject": {
          "type": "string",
          "default": "current",
          "enum": [
            "current",
            "all"
          ],
          "enumDescriptions": [
            "Show only sessions from the current workspace",
            "Show sessions from all projects"
          ],
          "description": "Default project filter when opening the sessions tab."
        },
        "claudeManager.sessions.restoreWindowMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 120,
          "description": "Time window (in minutes) for Restore Workspace — sessions active within this window are grouped together."
        },
        "claudeManager.marketplaceSkillsUrl": {
          "type": "string",
          "default": "https://github.com/anthropics/claude-code/wiki/Skills",
          "description": "URL opened by the 'Browse community skills' button on the Skills tab. Override to point at a curated team list."
        },
        "claudeManager.marketplaceMcpUrl": {
          "type": "string",
          "default": "https://mcp.so",
          "description": "URL opened by the 'Browse MCP servers' button on the MCP tab. Override to point at a curated team registry."
        },
        "claudeManager.sessions.resumeIn": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "terminal",
            "extension",
            "ask"
          ],
          "enumDescriptions": [
            "Resume in the surface the session originated from (extension chat if the session was started there, terminal otherwise)",
            "Always resume in a terminal (claude --resume)",
            "Always resume in the Claude Code extension chat tab (requires the official Claude Code extension)",
            "Ask every time where to resume"
          ],
          "description": "Where to open a session when you click Resume. Fork, Continue, and Restore Workspace always use the terminal since they have no equivalent in the extension chat."
        }
      }
    }
  },
  "scripts": {
    "build:extension": "node scripts/build-extension.mjs",
    "build:webview": "node scripts/build-webview.mjs",
    "build:css": "node scripts/build-css.js",
    "build": "node scripts/build-extension.mjs && node scripts/build-webview.mjs && node scripts/build-css.js",
    "watch:extension": "node scripts/build-extension.mjs --watch",
    "watch:webview": "node scripts/build-webview.mjs --watch",
    "watch": "node scripts/build-extension.mjs --watch & node scripts/build-webview.mjs --watch",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome format --write .",
    "size": "size-limit",
    "release": "npm test && npm run build && node -e \"require('fs').readdirSync('dist').filter(f=>f.endsWith('.vsix')).forEach(f=>require('fs').unlinkSync('dist/'+f))\" && npx @vscode/vsce package --no-dependencies -o dist/",
    "release:patch": "npm version patch --no-git-tag-version && npm run release",
    "release:minor": "npm version minor --no-git-tag-version && npm run release",
    "release:major": "npm version major --no-git-tag-version && npm run release",
    "publish:openvsx": "npx ovsx publish dist/*.vsix -p",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "pretest:integration": "npm run build && npm run compile:integration",
    "test:integration": "node ./out/integration/runTest.js",
    "perf:fixtures": "node scripts/perf/generate-fixtures.mjs",
    "perf:measure": "node scripts/perf/measure.mjs"
  },
  "size-limit": [
    {
      "path": "dist/extension.js",
      "limit": "400 KB"
    },
    {
      "path": "dist/webview/main.js",
      "limit": "60 KB"
    },
    {
      "name": "webview feature chunks (sum; all-native Preact UI — no @vscode-elements/lit vendor)",
      "path": "dist/webview/chunks/*.js",
      "limit": "60 KB"
    },
    {
      "path": "dist/webview/styles.css",
      "limit": "50 KB"
    }
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@size-limit/file": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "1.85.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "happy-dom": "^20.8.9",
    "mocha": "^11.7.6",
    "sharp": "^0.34.5",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "clsx": "^2.1.1",
    "preact": "^10.29.2",
    "valibot": "^1.4.0"
  }
}
