{
  "name": "claude-code-manager",
  "displayName": "Claude Code Manager",
  "description": "All-in-one manager for Claude Code — browse sessions, skills, commands, hooks, MCP servers, and agents from your sidebar",
  "version": "1.0.0",
  "publisher": "vishalguptax",
  "author": {
    "name": "Vishal Gupta",
    "url": "https://github.com/vishalguptax"
  },
  "license": "MIT",
  "icon": "media/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vishalguptax/claude-code-manager"
  },
  "homepage": "https://github.com/vishalguptax/claude-code-manager#readme",
  "bugs": {
    "url": "https://github.com/vishalguptax/claude-code-manager/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "session",
    "terminal",
    "ai",
    "mcp",
    "skills",
    "agents"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCodeManager",
          "title": "Claude Code Manager",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeCodeManager": [
        {
          "type": "webview",
          "id": "claudeCodeManager.view",
          "name": "Claude Code Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeManager.open",
        "title": "Claude: Open Code Manager"
      }
    ],
    "keybindings": [
      {
        "command": "claudeManager.open",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      }
    ]
  },
  "scripts": {
    "build:extension": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "esbuild src/webview/main.ts --bundle --outfile=dist/webview/main.js --format=iife --platform=browser",
    "copy:css": "node -e \"const fs=require('fs');const out=['src/styles/base.css','src/styles/components.css','src/styles/sessions.css','src/styles/skills.css','src/styles/features.css','src/styles/mcp.css','src/styles/agents.css'].map(f=>fs.readFileSync(f,'utf-8')).join('\\n');fs.mkdirSync('dist/webview',{recursive:true});fs.writeFileSync('dist/webview/styles.css',out)\"",
    "build": "npm run build:extension && npm run build:webview && npm run copy:css",
    "watch:extension": "npm run build:extension -- --watch",
    "watch:webview": "npm run build:webview -- --watch",
    "package": "npx vsce package --no-dependencies",
    "publish": "npx vsce publish --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "1.85.0",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.8.9",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
