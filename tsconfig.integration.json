{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "types": ["node", "mocha"],
    "outDir": "./out",
    "rootDir": "./test",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["test/**/*.ts"],
  "exclude": ["node_modules", "dist", "out"]
}
