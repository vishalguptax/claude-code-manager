{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "src/shared/**/*.ts",
      "src/core/lru.ts",
      "src/extension/registry.ts",
      "src/webview/app/**/*",
      "src/webview/shared/**/*",
      "src/features/*/webview/index.tsx",
      "scripts/build-extension.mjs",
      "scripts/build-webview.mjs",
      "!**/__tests__/**",
      "!**/*.test.ts",
      "!**/*.test.tsx"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "crlf"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noDoubleEquals": "error",
        "noDuplicateObjectKeys": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["src/webview/shared/**/*"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["**/features/**"],
                    "message": "FSD violation: src/webview/shared/** must not import from a feature slice (src/features/**)."
                  },
                  {
                    "group": ["**/app/**"],
                    "message": "FSD violation: src/webview/shared/** must not import from the app layer (src/webview/app/**)."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/account/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/agents/webview/**",
                      "**/features/agents/**",
                      "**/brain/webview/**",
                      "**/features/brain/**",
                      "**/commands/webview/**",
                      "**/features/commands/**",
                      "**/config/webview/**",
                      "**/features/config/**",
                      "**/diagnostics/webview/**",
                      "**/features/diagnostics/**",
                      "**/hooks/webview/**",
                      "**/features/hooks/**",
                      "**/mcp/webview/**",
                      "**/features/mcp/**",
                      "**/sessions/webview/**",
                      "**/features/sessions/**",
                      "**/skills/webview/**",
                      "**/features/skills/**"
                    ],
                    "message": "FSD violation: feature \"account\" must not import from another feature. Lift shared code into src/webview/shared or src/core."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/agents/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
